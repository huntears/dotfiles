{
    "workbench.colorTheme": "Catppuccin Macchiato",
    "terminal.integrated.sendKeybindingsToShell": true,
    "vim.smartRelativeLine": true,
    "[python]": {
        "editor.formatOnType": true
    },
    "editor.fontFamily": "'Fira Code', 'Droid Sans Mono', 'monospace', monospace",
    "editor.fontLigatures": true,
    "workbench.iconTheme": "catppuccin-macchiato",
    "extensions.ignoreRecommendations": true,
    "editor.formatOnSave": true,
    "editor.rulers": [
        80,
        120,
        160
    ],
    "zig.zigPath": "",
    "zig.zls.enabled": true,
    "zig.zls.path": "/home/huntears/.config/Code/User/globalStorage/ziglang.vscode-zig/zls_install/zls",
    "workbench.editorAssociations": {
        "*.db": "sqlite-viewer.option"
    },
    "window.menuBarVisibility": "toggle",
    "explorer.confirmDelete": false,
    "svelte.enable-ts-plugin": true,
    "files.insertFinalNewline": true,
    "files.exclude": {
        "**/*.d": true,
        "**/*.gcda": true,
        "**/*.gcno": true,
        "**/*.o": true,
        "**/.trunk/*actions/": true,
        "**/.trunk/*logs/": true,
        "**/.trunk/*notifications/": true,
        "**/.trunk/*out/": true,
        "**/.trunk/*plugins/": true
    },
    "epitech-c-cpp-headers.username": "",
    "epitech-c-cpp-headers.login": "",
    "epitech-c-cpp-headers.headerType": "post2017",
    "epitech-c-cpp-headers.usePragmaOnce": false,
    "epitech-c-cpp-headers.autoGenerateClasses": false,
    "C_Cpp.intelliSenseEngine": "disabled",
    "files.watcherExclude": {
        "**/.trunk/*actions/": true,
        "**/.trunk/*logs/": true,
        "**/.trunk/*notifications/": true,
        "**/.trunk/*out/": true,
        "**/.trunk/*plugins/": true
    },
    "editor.defaultFormatter": "xaver.clang-format",
    "[cpp]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    "telemetry.telemetryLevel": "off",
    "gitlens.telemetry.enabled": false,
    "haskell.manageHLS": "GHCup",
    "git.autofetch": true,
    "[groovy]": {
        "editor.defaultFormatter": "NicolasVuillamy.vscode-groovy-lint"
    },
    "audioCues.terminalCommandFailed": "on",
    "mesonbuild.downloadLanguageServer": true,
    "zig.path": "",
    "zig.initialSetupDone": true,
    "explorer.confirmDragAndDrop": false,
    "window.zoomLevel": 1
}
